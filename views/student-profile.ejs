<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Student Profile</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Inter', sans-serif;
    }

    body {
        background: linear-gradient(135deg, #0f172a, #020617);
        color: #fff;
        padding: 30px;
    }

    .container {
        max-width: 1000px;
        margin: auto;
        background: rgba(255,255,255,0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 20px;
        padding: 30px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.4);
    }

    h2 {
        font-size: 28px;
        margin-bottom: 25px;
        font-weight: 600;
    }

    .top-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 35px;
    }

    .passport {
        width: 120px;
        height: 120px;
        border-radius: 16px;
        object-fit: cover;
        border: 3px solid #22c55e;
    }

    .details p {
        margin: 6px 0;
        font-size: 15px;
        color: #cbd5f5;
    }

    .details strong {
        color: #fff;
    }

    .school-logo {
        width: 100px;
        opacity: 0.9;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        padding: 18px;
        border-radius: 14px;
        transition: 0.3s;
    }

    .card:hover {
        transform: translateY(-4px);
        border-color: #22c55e;
    }

    .card p {
        margin: 8px 0;
        font-size: 14px;
        color: #cbd5f5;
    }

    .card strong {
        color: #22c55e;
    }

    .chart-container {
        margin-top: 30px;
        background: rgba(255,255,255,0.03);
        padding: 20px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.05);
    }

    h3 {
        margin-bottom: 15px;
        font-weight: 500;
    }
.results-section {
    margin-top: 30px;
}


.status {
    font-size: 12px;
    padding: 4px 8px;
    border-radius: 6px;
}

.pass {
    background: rgba(34,197,94,0.2);
    color: #22c55e;
}

.fail {
    background: rgba(239,68,68,0.2);
    color: #ef4444;
}


    .btn {
        margin-top: 25px;
        padding: 12px 22px;
        border: none;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: #fff;
        border-radius: 10px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 500;
        transition: 0.3s;
        box-shadow: 0 5px 20px rgba(34,197,94,0.4);
    }

    .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(34,197,94,0.6);
    }

    .btn:active {
        transform: scale(0.96);
    }
.result-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #1e293b;
    padding: 12px;
    border-radius: 8px;
    margin-bottom: 10px;
    color: #fff;
}

.status.pass {
    color: #22c55e;
}

.status.fail {
    color: #ef4444;
}

.student-box {
    display: flex;
    align-items: center;
    gap: 15px;
}

.school-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
}

.school-name {
    margin-top: 8px;
    font-size: 14px;
    color: #cbd5f5;
}
.results-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
    margin-top: 15px;
}

.result-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.08);
    padding: 16px;
    border-radius: 14px;
    transition: 0.3s;
    display: flex;
    flex-direction: column;
    gap: 15px;
}

.result-card:hover {
    transform: translateY(-4px);
    border-color: #22c55e;
}

.result-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.term {
    font-weight: 600;
}

.session {
    font-size: 12px;
    color: #94a3b8;
}

.avg {
    font-size: 18px;
    font-weight: bold;
}

.status {
    font-size: 11px;
    padding: 4px 8px;
    border-radius: 6px;
}

.pass {
    background: rgba(34,197,94,0.2);
    color: #22c55e;
}

.fail {
    background: rgba(239,68,68,0.2);
    color: #ef4444;
}

.view-btn {
    width: 100%;
    background: #22c55e;
    border: none;
    padding: 10px;
    border-radius: 8px;
    color: #fff;
    cursor: pointer;
    transition: 0.3s;
}

.view-btn:hover {
    background: #16a34a;
}
    @media (max-width: 700px) {
        .top-section {
            flex-direction: column;
            text-align: center;
        }

        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>
</head>

<body>

<div class="container">
    <h2>🎓 Student Profile</h2>

   <div class="top-section">

    <!-- LEFT: STUDENT -->
    <div class="student-box">
        <img class="passport" 
        src="<%= student.passport || 'https://via.placeholder.com/150' %>" />

        <div class="details">
            <p><strong>Name:</strong> <%= student.userName %></p>
            <p><strong>ID:</strong> <%= student.studentId %></p>
            <p><strong>Session:</strong> <%= student.schoolsession %></p>
        </div>
    </div>

    <!-- RIGHT: SCHOOL -->
    <div class="school-box">
        <img 
          src="/IMAGE/<%= encodeURIComponent(student.schoolName.toLowerCase()) %>.png"
          class="school-logo"
        />
        <h3 class="school-name"><%= student.schoolName %></h3>
    </div>

</div>

    <div class="grid">
        <div class="card">
            <p><strong>Admission No:</strong> <%= student.addmissionNo || 'N/A' %></p>
            <p><strong>Class:</strong> <%= student.class %></p>
        </div>

        <div class="card">
            <p><strong>DOB:</strong> <%= student.dob || 'N/A' %></p>
            <p><strong>Gender:</strong> <%= student.gender || 'N/A' %></p>
        </div>
    </div>

    <div class="chart-container">
        <h3>📈 Performance</h3>
        <canvas id="performanceChart"></canvas>
    </div>

   <div class="results-section">
    <h3>📄 Student Results</h3>

    <div class="results-list"></div>
</div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    getResult('<%= student.studentId %>');
});

async function getResult(studentId) {
    try {
        const response = await fetch(`/api/get_result?studentId=${studentId}`);
        const data = await response.json();

        resultAnalysisA(data);
    } catch (err) {
        console.error("Error fetching result:", err);
    }
}

function resultAnalysisA(data) {
   
    const labels = [];
    const scores = [];

    data.forEach(res => {
        labels.push(res.term);
        scores.push(res.average);
    });

    const ctx = document.getElementById('performanceChart').getContext('2d');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels,
            datasets: [{
                label: 'Average Score',
                data: scores,
                borderColor: '#22c55e',
                backgroundColor: 'rgba(34,197,94,0.2)',
                fill: true,
                tension: 0.4
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { labels: { color: "#fff" } }
            },
            scales: {
                x: { ticks: { color: "#cbd5f5" } },
                y: { ticks: { color: "#cbd5f5" }, beginAtZero: true }
            }
        }
    });

    renderResults(data);
}

function renderResults(data) {
    const container = document.querySelector('.results-list');
     console.log(data);
    let html = '';

    data.forEach(item => {
        const status = item.average >= 50 ? 'pass' : 'fail';

        html += `
            <div class="result-card">
                
                <div class="result-top">
                    <div>
                        <p class="term">${item.term}</p>
                        <p class="session">${item.class}</p>
                        <p class="session">${item.session}</p>
                    </div>

                    <div class="result-stats">
                        <p class="avg">${item.average}</p>
                        <span class="status ${status}">
                            ${status.toUpperCase()}
                        </span>
                    </div>
                </div>

                <button 
                    class="view-btn"
                    onclick="viewResult('${item.studentId}', '${item.term}', '${item.class}', '${item.schoolName}')"
                >
                    View Full Result →
                </button>

            </div>
        `;
    });

    container.innerHTML = html;
}

// NAVIGATION FUNCTION
function viewResult(studentId, term, sclass, school) {
    console.log(studentId, term, sclass, school);
    window.location.href = `/view-student-result?studentId=${studentId}&term=${term}&sclass=${sclass}&school=${school}`;
}


</script>

</body>
</html>