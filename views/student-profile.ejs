<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Student Profile</title>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        font-family: Arial, sans-serif;
        background: #f5f7fb;
        margin: 0;
        padding: 20px;
    }

    .container {
        max-width: 1000px;
        margin: auto;
        background: #fff;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
    }

    h2 {
        margin-bottom: 20px;
        color: #333;
    }

    .top-section {
        display: flex;
        gap: 20px;
        align-items: center;
        margin-bottom: 30px;
    }

    .passport {
        width: 140px;
        height: 140px;
        border-radius: 10px;
        object-fit: cover;
        border: 3px solid #4CAF50;
    }

    .details p {
        margin: 6px 0;
        font-size: 16px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 15px;
        margin-bottom: 30px;
    }

    .card {
        background: #f9f9f9;
        padding: 15px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .card strong {
        color: #4CAF50;
    }

    .chart-container {
        margin-top: 30px;
    }

    .btn {
        margin-top: 20px;
        padding: 10px 18px;
        border: none;
        background: #4CAF50;
        color: #fff;
        border-radius: 6px;
        cursor: pointer;
        font-size: 14px;
        transition: 0.3s;
    }

    .btn:hover {
        background: #45a049;
    }

    .btn:active {
        transform: scale(0.97);
    }

    @media (max-width: 700px) {
        .top-section {
            flex-direction: column;
            text-align: center;
        }

        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>
</head>

<body>

<div class="container">
    <h2>Student Profile</h2>

    <!-- TOP SECTION -->
    <div class="top-section">
        <img class="passport" 
             src="<%= student.passport || 'https://via.placeholder.com/150' %>" 
             alt="passport">

        <div class="details">
            <p><strong>Name:</strong> <%= student.userName %></p>
            <p><strong>ID:</strong> <%= student.studentId %></p>
            <p><strong>School:</strong> <%= student.schoolName %></p>
            <p><strong>Session:</strong> <%= student.schoolsession %></p>
        </div>
    </div>

    <!-- DETAILS -->
    <div class="grid">
        <div class="card">
            <p><strong>Admission No:</strong> <%= student.addmissionNo || 'N/A' %></p>
            <p><strong>Class:</strong> <%= student.class %></p>
        </div>

        <div class="card">
            <p><strong>DOB:</strong> <%= student.dob || 'N/A' %></p>
            <p><strong>Gender:</strong> <%= student.gender || 'N/A' %></p>
        </div>
    </div>

    <!-- PERFORMANCE CHART -->
    <div class="chart-container">
        <h3>Performance (Mock Data)</h3>
        <canvas id="performanceChart"></canvas>
    </div>

    <!-- VIEW BUTTON -->
    <button class="btn" id="viewResultBtn">View Full Result</button>
</div>

<script>
    // MOCK DATA (Replace later with real data from backend)
    const labels = ["Term 1", "Term 2", "Term 3", "Term 4"];
    const scores = [65, 70, 80, 75];

    const ctx = document.getElementById('performanceChart').getContext('2d');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Average Score',
                data: scores,
                borderWidth: 2,
                tension: 0.3
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100
                }
            }
        }
    });

    // VIEW BUTTON NAVIGATION
    document.getElementById('viewResultBtn').addEventListener('click', () => {
        const studentId = "<%= student.studentId %>";
        window.location.href = `/student-result/${studentId}`;
    });
</script>

</body>
</html>